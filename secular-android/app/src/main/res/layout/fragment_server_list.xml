<?xml version="1.0" encoding="utf-8"?>
<!-- Server List Screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    tools:context=".ui.ServerListFragment">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:text="My Servers"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No servers yet"
            android:textSize="16sp"
            android:textColor="@color/text_dim"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_first_server"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add your first server"
            android:textColor="@color/bg"
            android:textStyle="bold"
            app:backgroundTint="@color/accent"
            app:cornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </LinearLayout>

    <!-- Server List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/server_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- Bottom Nav: same 3-button layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:paddingHorizontal="32dp"
        android:paddingBottom="36dp">

        <!-- Query Log button -->
        <ImageButton
            android:id="@+id/nav_log"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_log"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="Query log" />

        <!-- Home button — green circle 56dp -->
        <FrameLayout
            android:id="@+id/nav_home_btn"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="-8dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/nav_home_circle"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_home"
                android:tint="@color/bg" />
        </FrameLayout>

        <!-- Add Server button -->
        <ImageButton
            android:id="@+id/nav_add"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add_circle_outline"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="Add server" />
    </LinearLayout>

</LinearLayout>
