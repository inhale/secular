<?xml version="1.0" encoding="utf-8"?>
<!-- secular-android/app/src/main/res/layout/fragment_server_list.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    tools:context=".ui.ServerListFragment">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:text="My Servers"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium" />

    <!-- Empty state (shown when no servers) -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No servers yet"
            android:textSize="16sp"
            android:textColor="@color/text_dim"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_first_server"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add your first server"
            android:textColor="@color/bg"
            app:backgroundTint="@color/accent"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </LinearLayout>

    <!-- Server List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/server_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- Bottom Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="32dp"
        android:paddingBottom="36dp">

        <ImageButton
            android:id="@+id/nav_servers"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_grid"
            android:scaleType="centerInside"
            android:tint="@color/accent"
            android:contentDescription="Server list" />

        <FrameLayout
            android:id="@+id/nav_home"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginTop="-12dp"
            android:background="@drawable/nav_home_circle"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp"
            android:layout_marginHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_home"
                android:tint="@color/bg" />
        </FrameLayout>

        <ImageButton
            android:id="@+id/nav_add"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="Add server" />
    </LinearLayout>

</LinearLayout>
