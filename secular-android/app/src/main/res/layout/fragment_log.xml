<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    tools:context=".ui.LogFragment">

    <!-- Header with actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Query Log"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- Filter button with badge -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp">

            <ImageButton
                android:id="@+id/btn_filter_log"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_filter"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:tint="@color/text_dim"
                android:contentDescription="Filter log" />

            <!-- Badge dot: shown when any filter is off -->
            <View
                android:id="@+id/filter_badge"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:background="@drawable/ping_dot_excellent"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Copy button -->
        <ImageButton
            android:id="@+id/btn_copy_log"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_copy"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:tint="@color/text_dim"
            android:contentDescription="Copy log" />

        <!-- Clear button -->
        <ImageButton
            android:id="@+id/btn_clear_log"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_trash"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:tint="@color/text_dim"
            android:contentDescription="Clear log" />
    </LinearLayout>

    <!-- Log output area: styled dark card with border (matches mockup #0D0D0D) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/log_window_bg">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/log_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="6dp"
            android:paddingVertical="8dp"
            android:clipToPadding="false"
            android:scrollbarStyle="outsideOverlay" />

        <!-- Scroll-to-bottom hint -->
        <TextView
            android:id="@+id/scroll_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@drawable/scroll_hint_bg"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="↓ New entries"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Selection toolbar -->
        <LinearLayout
            android:id="@+id/selection_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/selection_bar_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/sel_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 lines selected"
                android:textColor="@color/text_dim"
                android:textSize="11sp" />

            <ImageButton
                android:id="@+id/btn_copy_selected"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_copy"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:tint="@color/text_dim"
                android:contentDescription="Copy selected" />

            <ImageButton
                android:id="@+id/btn_clear_selection"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:tint="@color/text_dim"
                android:contentDescription="Clear selection" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom Nav: flat icon row, Query log active -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="48dp"
        android:paddingVertical="16dp">

        <!-- Query log (active) -->
        <ImageButton
            android:id="@+id/nav_log"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_log"
            android:scaleType="centerInside"
            android:tint="@color/accent"
            android:contentDescription="Query log" />

        <ImageButton
            android:id="@+id/nav_home_btn"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_home"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="Home" />

        <ImageButton
            android:id="@+id/nav_add"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add_circle_outline"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="Add server" />
    </LinearLayout>

</LinearLayout>
