<?xml version="1.0" encoding="utf-8"?>
<!-- Add Server Screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    tools:context=".ui.AddServerFragment">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        android:text="Add Connection"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="20dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section: Insert Link -->
            <TextView
                style="@style/FieldLabel"
                android:text="Insert Link" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <EditText
                    android:id="@+id/field_link"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/field_input_bg"
                    android:paddingHorizontal="16dp"
                    android:hint="Paste tt:// or ss:// link"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#30FFFFFF"
                    android:inputType="text"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_link"
                    android:layout_width="64dp"
                    android:layout_height="48dp"
                    android:text="Add"
                    android:textColor="@color/bg"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    app:backgroundTint="@color/accent"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Supports Outline, Shadowsocks, VLESS keys"
                android:textSize="10sp"
                android:textColor="#40FFFFFF" />

            <!-- OR Divider -->
            <include layout="@layout/or_divider" />

            <!-- Scan QR Code Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scan_qr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:text="Scan QR Code"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                app:backgroundTint="#0AFFFFFF"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_qr"
                app:iconTint="@color/accent"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

            <!-- OR Divider -->
            <include layout="@layout/or_divider" />

            <!-- Upload .toml file Button -->
            <FrameLayout
                android:id="@+id/btn_upload_config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:background="@drawable/upload_zone_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_file_upload"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/accent"
                    android:gravity="center_vertical"
                    android:text="Upload .toml file"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- OR Divider -->
            <include layout="@layout/or_divider" />

            <!-- Add Server Manually Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_manual_setup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:text="Add Server Manually"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                app:backgroundTint="#0AFFFFFF"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_add_circle"
                app:iconTint="@color/accent"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav: same 3-button layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:paddingHorizontal="32dp"
        android:paddingBottom="36dp">

        <ImageButton
            android:id="@+id/nav_log"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_log"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="Query log" />

        <FrameLayout
            android:id="@+id/nav_home_btn"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="-8dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/nav_home_circle"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_home"
                android:tint="@color/bg" />
        </FrameLayout>

        <!-- Add button — highlighted (current screen) -->
        <ImageButton
            android:id="@+id/nav_add"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add_circle_outline"
            android:scaleType="centerInside"
            android:tint="@color/accent"
            android:contentDescription="Add server" />
    </LinearLayout>

</LinearLayout>
