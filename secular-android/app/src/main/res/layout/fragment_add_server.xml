<?xml version="1.0" encoding="utf-8"?>
<!-- secular-android/app/src/main/res/layout/fragment_add_server.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    tools:context=".ui.AddServerFragment">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="8dp"
        android:text="Add Connection"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section: Insert Link -->
            <TextView
                style="@style/FieldLabel"
                android:text="Insert Link" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <EditText
                    android:id="@+id/field_link"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/field_input_bg"
                    android:paddingHorizontal="16dp"
                    android:hint="Paste tt:// or ss:// link"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#30FFFFFF"
                    android:inputType="text"
                    android:layout_marginEnd="10dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_link"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Add"
                    android:textColor="@color/bg"
                    android:textStyle="bold"
                    app:backgroundTint="@color/accent"
                    app:cornerRadius="12dp" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Supports Outline, Shadowsocks, VLESS keys"
                android:textSize="11sp"
                android:textColor="#40FFFFFF" />

            <!-- OR Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginVertical="24dp">
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:text="or"
                    android:textSize="11sp"
                    android:textColor="@color/text_dim"
                    android:textAllCaps="true"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
            </LinearLayout>

            <!-- Section: Scan QR Code -->
            <TextView
                style="@style/FieldLabel"
                android:text="Scan QR Code" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scan_qr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="64dp"
                android:text="Scan QR Code"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="#0AFFFFFF"
                app:strokeColor="@color/border"
                app:strokeWidth="1.5dp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_qr"
                app:iconTint="@color/accent"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

            <!-- OR Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginVertical="24dp">
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:text="or"
                    android:textSize="11sp"
                    android:textColor="@color/text_dim"
                    android:textAllCaps="true"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
            </LinearLayout>

            <!-- Section: Upload Config -->
            <TextView
                style="@style/FieldLabel"
                android:text="Upload Config" />
            <LinearLayout
                android:id="@+id/btn_upload_config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp"
                android:background="@drawable/upload_zone_bg"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_file_upload"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload .toml file"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tap to browse"
                    android:textSize="12sp"
                    android:textColor="@color/text_dim"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- OR Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginVertical="24dp">
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:text="or"
                    android:textSize="11sp"
                    android:textColor="@color/text_dim"
                    android:textAllCaps="true"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
            </LinearLayout>

            <!-- Section: Manual Setup -->
            <TextView
                style="@style/FieldLabel"
                android:text="Manual Setup" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_manual_setup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="64dp"
                android:text="Add Server Manually"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="#0AFFFFFF"
                app:strokeColor="@color/border"
                app:strokeWidth="1.5dp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_add_circle"
                app:iconTint="@color/accent"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Enter server details by hand"
                android:textSize="12sp"
                android:textColor="@color/text_dim" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:paddingTop="12dp"
        android:paddingBottom="44dp">

        <ImageButton
            android:id="@+id/nav_servers"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_grid"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="Server list" />

        <!-- Home button -->
        <ImageButton
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_home"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="Home" />

        <ImageButton
            android:id="@+id/nav_add"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add"
            android:scaleType="centerInside"
            android:tint="@color/accent"
            android:contentDescription="Add server" />

        <!-- Log button -->
        <ImageButton
            android:id="@+id/nav_log"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_log"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="Log" />
    </LinearLayout>

</LinearLayout>
