<?xml version="1.0" encoding="utf-8"?>
<!-- Dashboard Screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    tools:context=".ui.DashboardFragment">

    <!-- Status Bar spacer with log button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp">

        <ImageButton
            android:id="@+id/btn_log"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="20dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_log"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="VPN Log" />
    </FrameLayout>

    <!-- Status Label -->
    <TextView
        android:id="@+id/status_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disconnected"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:textColor="@color/text_dim"
        android:layout_marginBottom="8dp" />

    <!-- Metrics Row -->
    <LinearLayout
        android:id="@+id/metrics_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:alpha="0.35"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="32dp">
            <TextView
                android:id="@+id/session_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Session"
                android:textSize="10sp"
                android:textColor="@color/text_dim"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="32dp">
            <TextView
                android:id="@+id/dl_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— MB"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Download"
                android:textSize="10sp"
                android:textColor="@color/text_dim"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/ul_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— MB"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload"
                android:textSize="10sp"
                android:textColor="@color/text_dim"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Spacer to push connect button to vertical center -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Connect Button: large circle with thin gray border -->
    <FrameLayout
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginBottom="24dp">

        <!-- Spinning ring (connected state) -->
        <View
            android:id="@+id/connect_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/connect_ring"
            android:visibility="invisible" />

        <!-- Main button circle: thin gray border, dark fill, white logo -->
        <ImageButton
            android:id="@+id/connect_btn"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/connect_btn_bg"
            android:src="@drawable/logo_white"
            android:scaleType="fitCenter"
            android:padding="50dp"
            android:contentDescription="Toggle VPN connection"
            android:stateListAnimator="@null" />
    </FrameLayout>

    <!-- Spacer between connect button and server card -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Server Card -->
    <LinearLayout
        android:id="@+id/server_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/server_card_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <!-- Text block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/server_card_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                tools:text="Frankfurt #1" />

            <TextView
                android:id="@+id/server_card_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:textColor="@color/text_dim"
                android:fontFamily="monospace"
                android:letterSpacing="0.02"
                tools:text="TrustTunnel · 185.103.24.4:443" />
        </LinearLayout>

        <!-- Ping dot -->
        <View
            android:id="@+id/ping_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/ping_dot_bg"
            android:layout_marginEnd="8dp" />

        <!-- Flag circle -->
        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/flag_circle_bg">

            <TextView
                android:id="@+id/flag_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="16sp"
                tools:text="🇩🇪"
                tools:ignore="HardcodedText" />
        </FrameLayout>
    </LinearLayout>

    <!-- Bottom Nav: 3 buttons with center green circle home -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:paddingHorizontal="32dp"
        android:paddingBottom="36dp">

        <!-- Grid / Server List button -->
        <ImageButton
            android:id="@+id/nav_servers"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_grid"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="Server list" />

        <!-- Home button — green circle 56dp -->
        <FrameLayout
            android:id="@+id/nav_home_btn"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="-8dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/nav_home_circle"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_home"
                android:tint="@color/bg" />
        </FrameLayout>

        <!-- Add Server button -->
        <ImageButton
            android:id="@+id/nav_add"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add_circle_outline"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="Add server" />
    </LinearLayout>

</LinearLayout>
