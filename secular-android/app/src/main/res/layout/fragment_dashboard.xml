<?xml version="1.0" encoding="utf-8"?>
<!-- Dashboard Screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    tools:context=".ui.DashboardFragment">

    <!-- Status zone: log button top-right, status below -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <ImageButton
            android:id="@+id/btn_log"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="20dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_log"
            android:scaleType="centerInside"
            android:tint="@color/text_dim"
            android:contentDescription="VPN Log" />
    </FrameLayout>

    <!-- Status Label -->
    <TextView
        android:id="@+id/status_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disconnected"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:textColor="@color/text_dim" />

    <!-- Metrics Row -->
    <LinearLayout
        android:id="@+id/metrics_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:alpha="0.35">

        <!-- Session -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="32dp">
            <TextView
                android:id="@+id/session_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SESSION"
                android:textSize="10sp"
                android:textColor="@color/text_dim"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />
        </LinearLayout>

        <!-- Download -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="32dp">
            <TextView
                android:id="@+id/dl_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DOWNLOAD PKTS"
                android:textSize="10sp"
                android:textColor="@color/text_dim"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />
        </LinearLayout>

        <!-- Upload -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/ul_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPLOAD PKTS"
                android:textSize="10sp"
                android:textColor="@color/text_dim"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Spacer to push connect button to vertical center -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Connect Button Area -->
    <FrameLayout
        android:id="@+id/connect_btn_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <!-- Glow background (visible when connected, behind everything) -->
        <View
            android:id="@+id/connect_glow"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:background="@drawable/connect_glow_bg"
            android:visibility="gone" />

        <!-- The actual clickable button: circle with border, contains logo images -->
        <FrameLayout
            android:id="@+id/connect_btn"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="@drawable/connect_btn_bg"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Toggle VPN connection">

            <!-- White logo (shown when disconnected) -->
            <ImageView
                android:id="@+id/logo_dim"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/logo_white"
                android:scaleType="fitCenter"
                android:importantForAccessibility="no" />

            <!-- Green logo (shown when connected) -->
            <ImageView
                android:id="@+id/logo_bright"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/logo_green"
                android:scaleType="fitCenter"
                android:visibility="gone"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <!-- Spinning ring overlay (visible when connected) -->
        <View
            android:id="@+id/connect_ring"
            android:layout_width="196dp"
            android:layout_height="196dp"
            android:layout_gravity="center"
            android:background="@drawable/connect_ring"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Spacer between connect button and server card -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Server Card -->
    <LinearLayout
        android:id="@+id/server_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/server_card_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <!-- Text block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/server_card_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                tools:text="Frankfurt #1" />

            <TextView
                android:id="@+id/server_card_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:textColor="@color/text_dim"
                android:fontFamily="monospace"
                android:letterSpacing="0.02"
                tools:text="TrustTunnel · 185.103.24.4:443" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="11sp"
                android:textColor="@color/text_dim"
                android:alpha="0.5"
                android:text="Tap to change server" />
        </LinearLayout>

        <!-- Ping dot -->
        <View
            android:id="@+id/ping_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/ping_dot_bg"
            android:layout_marginEnd="12dp" />
    </LinearLayout>

    <!-- Bottom Nav: icons only -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="32dp"
        android:paddingBottom="36dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Query Log button -->
            <ImageButton
                android:id="@+id/nav_log"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_log"
                android:scaleType="centerInside"
                android:tint="@color/text_dim"
                android:contentDescription="Query log" />

            <!-- Spacer for center button -->
            <View
                android:layout_width="56dp"
                android:layout_height="1dp" />

            <!-- Add Server button -->
            <ImageButton
                android:id="@+id/nav_add"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_add_circle_outline"
                android:scaleType="centerInside"
                android:tint="@color/text_dim"
                android:contentDescription="Add server" />
        </LinearLayout>

        <!-- Home button (green circle, centered, overlapping) -->
        <FrameLayout
            android:id="@+id/nav_home_btn"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:layout_marginBottom="-8dp"
            android:background="@drawable/nav_home_circle"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_home"
                android:tint="@color/bg"
                android:importantForAccessibility="no" />
        </FrameLayout>
    </FrameLayout>

</LinearLayout>
