<?xml version="1.0" encoding="utf-8"?>
<!-- Server list item: server name, meta, gear icon, optional DEFAULT badge -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp"
    android:paddingHorizontal="16dp"
    android:layout_marginBottom="4dp"
    android:background="@drawable/server_item_bg"
    android:clickable="true"
    android:focusable="true">

    <!-- Server info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Default badge (shown only for selected/default server) -->
        <TextView
            android:id="@+id/default_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/default_badge_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:text="* DEFAULT"
            android:textColor="@color/accent"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:visibility="gone"
            tools:text="* DEFAULT" />

        <TextView
            android:id="@+id/server_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="Frankfurt #1" />

        <TextView
            android:id="@+id/server_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:textColor="@color/text_dim"
            tools:text="TrustTunnel · 185.103.24.4:443" />
    </LinearLayout>

    <!-- Gear icon -->
    <ImageButton
        android:id="@+id/gear_btn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_gear"
        android:scaleType="centerInside"
        android:contentDescription="Edit server" />

</LinearLayout>
