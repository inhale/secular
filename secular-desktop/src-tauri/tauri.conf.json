{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/.schema/config.schema.json",
  "productName": "Secular",
  "version": "0.1.0",
  "identifier": "com.secular.vpn",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Secular",
        "width": 360,
        "height": 520,
        "resizable": false,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/256x256@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    },
    "targets": ["dmg", "app"]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
