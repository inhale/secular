{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Secular",
  "version": "0.1.0",
  "identifier": "com.secular.vpn",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Secular",
        "width": 360,
        "height": 700,
        "resizable": false,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/1024x1024.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/tray-active.png",
      "icons/tray-active@2x.png",
      "icons/tray-inactive.png",
      "icons/tray-inactive@2x.png"
    ],
    "resources": [
      "icons/tray-active.png",
      "icons/tray-active@2x.png",
      "icons/tray-inactive.png",
      "icons/tray-inactive@2x.png"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    },
    "targets": ["app", "dmg", "deb", "appimage", "nsis"]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
